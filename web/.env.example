# GAS Web アプリの /exec URL（サーバー用・Workspace 埋め込み用で同じ値）
GAS_WEB_APP_URL=https://script.google.com/macros/s/xxxxx/exec
NEXT_PUBLIC_GAS_WEB_APP_URL=https://script.google.com/macros/s/xxxxx/exec

# GAS スクリプトプロパティ WS_API_TOKEN と同じ値
GAS_API_TOKEN=your-random-secret

# 以下は使わない想定（AI 生成を有効にするときだけ）
# GEMINI_API_KEY=
